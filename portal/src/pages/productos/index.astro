---
import MainLayout from '../../layouts/MainLayout.astro';
import PageHero from '../../components/PageHero.astro';

// Fetch data from CMS
const productosResponse = await fetch('http://localhost:3000/api/productos?XTransformPort=3000');
const productosData = await productosResponse.json();
const productos = productosData.productos || [];

const categoriasResponse = await fetch('http://localhost:3000/api/categorias?XTransformPort=3000');
const categoriasData = await categoriasResponse.json();
const categorias = categoriasData.categorias || [];
---

<MainLayout title="Productos" description="Catalogo de productos caprinos de Finca La Habanera - Quesos, yogures, leche y mas">
  <!-- Hero -->
  <PageHero 
    title="Nuestros Productos"
    subtitle="Descubra nuestra variedad de productos lacteos caprinos artesanales, elaborados con amor y tradicion en nuestra finca"
    backgroundImage="https://images.unsplash.com/photo-1486297678162-eb2a19b0a32d?w=1920&q=80"
    height="medium"
    badge="Catalogo"
  />

  <section class="section productos-page">
    <div class="container">
      <!-- Filtros por categoria -->
      <div class="filtros">
        <button class="filtro-btn active" data-categoria="todos">
          Todos
        </button>
        {categorias.map((cat: any) => (
          <button class="filtro-btn" data-categoria={cat.nombre.toLowerCase()}>
            {cat.nombre}
          </button>
        ))}
      </div>
      
      <!-- Grid de productos -->
      {productos.length > 0 ? (
        <div class="grid grid-3 productos-grid">
          {productos.map((producto: any) => (
            <article class="card producto-card" data-categoria={producto.categoria?.nombre?.toLowerCase() || 'otros'}>
              <img 
                src={producto.imagen || 'https://images.unsplash.com/photo-1486297678162-eb2a19b0a32d?w=800&q=80'} 
                alt={producto.nombre}
                class="card-image"
                loading="lazy"
              />
              <div class="card-content">
                <span class="badge badge-primary">{producto.categoria?.nombre || 'Producto'}</span>
                <h3 class="card-title">{producto.nombre}</h3>
                <p class="card-text">{producto.descripcion}</p>
                <a 
                  href={`https://wa.me/5353972047?text=Hola%2C%20estoy%20interesado%2Fa%20en%20el%20producto%20${encodeURIComponent(producto.nombre)}.%20%C2%BFPodrian%20darme%20mas%20informacion%3F`}
                  target="_blank"
                  rel="noopener"
                  class="btn btn-accent btn-sm"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                  </svg>
                  Consultar por WhatsApp
                </a>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <p class="no-products">No hay productos disponibles en este momento.</p>
      )}
      
      <!-- Nota sobre precios -->
      <div class="nota-precios">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <path d="M12 16v-4"/>
          <path d="M12 8h.01"/>
        </svg>
        <p>Los precios no se muestran en el sitio web. Contactenos por WhatsApp para obtener informacion detallada sobre precios y disponibilidad.</p>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .productos-page {
    background-color: var(--color-crema);
  }
  
  .filtros {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }
  
  .filtro-btn {
    padding: 0.5rem 1rem;
    background-color: transparent;
    border: 2px solid var(--color-queso);
    border-radius: 9999px;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-chocolate);
    cursor: pointer;
    transition: all 0.2s ease;
  }
  
  .filtro-btn:hover {
    border-color: var(--color-mantequilla);
    background-color: var(--color-queso);
  }
  
  .filtro-btn.active {
    background-color: var(--color-mantequilla);
    border-color: var(--color-mantequilla);
    color: var(--color-chocolate);
  }
  
  .productos-grid {
    margin-bottom: 2rem;
  }
  
  .producto-card {
    display: flex;
    flex-direction: column;
  }
  
  .producto-card .card-content {
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  
  .producto-card .badge {
    width: fit-content;
    margin-bottom: 0.5rem;
  }
  
  .producto-card .btn {
    margin-top: auto;
    width: 100%;
  }
  
  .btn-sm {
    padding: 0.5rem 1rem;
    font-size: 0.875rem;
  }
  
  .no-products {
    text-align: center;
    color: var(--color-tierra);
    padding: 2rem;
  }
  
  .nota-precios {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.5rem;
    background-color: var(--color-queso);
    border-radius: 1rem;
    margin-top: 2rem;
  }
  
  .nota-precios svg {
    flex-shrink: 0;
    color: var(--color-mantequilla);
  }
  
  .nota-precios p {
    color: var(--color-cafe);
    font-size: 0.9rem;
    margin: 0;
  }
  
  .producto-card.hidden {
    display: none;
  }
</style>

<script>
  // Filtro de categorias
  const filtrosBtns = document.querySelectorAll('.filtro-btn');
  const productosCards = document.querySelectorAll('.producto-card');
  
  filtrosBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      // Actualizar estado activo
      filtrosBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      
      // Filtrar productos
      const categoria = btn.getAttribute('data-categoria');
      
      productosCards.forEach(card => {
        if (categoria === 'todos' || card.getAttribute('data-categoria') === categoria) {
          card.classList.remove('hidden');
        } else {
          card.classList.add('hidden');
        }
      });
    });
  });
</script>