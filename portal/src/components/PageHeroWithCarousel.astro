---
// components/PageHeroWithCarousel.astro
import CarruselFondo from "./CarruselFondo.astro";

export interface Slide {
    id: string;
    tipo: "imagen" | "video";
    url: string;
    titulo: string | null;
    subtitulo: string | null;
    duracion: number;
    orden: number;
    activo: boolean;
}

export interface Props {
    slides: Slide[];
    title: string;
    subtitle?: string;
    overlay?: boolean;
    height?: 'half' | 'full' | 'medium' | 'large';
    align?: 'center' | 'left';
    showScrollIndicator?: boolean;
    badge?: string;
    primaryCta?: { text: string; href: string };
    secondaryCta?: { text: string; href: string };
}

const {
    slides,
    title,
    subtitle,
    overlay = true,
    height = 'large',
    align = 'center',
    showScrollIndicator = false,
    badge,
    primaryCta,
    secondaryCta
} = Astro.props;

const slidesActivos = slides.filter(s => s.activo).sort((a, b) => a.orden - b.orden);
const alignmentClass = align === 'left' ? 'hero-align-left' : 'hero-align-center';
---

<section class={`page-hero hero-${height} ${alignmentClass}`}>
    {/* Carrusel de fondo */}
    <CarruselFondo slides={slidesActivos} />

    {overlay && <div class="hero-overlay"></div>}

    <div class="hero-content">
        {badge && <span class="hero-badge">{badge}</span>}
        <h1 class="hero-title">{title}</h1>
        {subtitle && <p class="hero-subtitle">{subtitle}</p>}

        {(primaryCta || secondaryCta) && (
            <div class="hero-ctas">
                {primaryCta && (
                    <a href={primaryCta.href} class="btn btn-primary btn-hero">
                        {primaryCta.text}
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M5 12h14"/>
                            <path d="m12 5 7 7-7 7"/>
                        </svg>
                    </a>
                )}
                {secondaryCta && (
                    <a href={secondaryCta.href} class="btn btn-outline-hero">
                        {secondaryCta.text}
                    </a>
                )}
            </div>
        )}
    </div>

    {showScrollIndicator && (
        <button class="scroll-indicator" aria-label="Desplazar hacia abajo">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 5v14"/>
                <path d="m19 12-7 7-7-7"/>
            </svg>
        </button>
    )}
</section>

<style is:global>
    .page-hero {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        overflow: hidden;
    }

    /* Alturas */
    .hero-half { min-height: 45vh; }
    .hero-medium { min-height: 60vh; }
    .hero-large { min-height: 90vh; }
    .hero-full { min-height: 100vh; }

    @media (max-width: 768px) {
        .hero-half { min-height: 40vh; }
        .hero-medium { min-height: 50vh; }
        .hero-large { min-height: 70vh; }
        .hero-full { min-height: 80vh; }
    }

    .hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            135deg,
            rgba(61, 35, 20, 0.55) 0%,
            rgba(61, 35, 20, 0.7) 50%,
            rgba(61, 35, 20, 0.6) 100%
        );
        z-index: 2;
    }

    .hero-content {
        position: relative;
        z-index: 3;
        text-align: center;
        padding: 2rem 1.5rem;
        width: 100%;
        max-width: 100%;
    }

    .hero-align-left .hero-content {
        text-align: left;
    }

    @media (min-width: 768px) {
        .hero-content { padding: 2.5rem 3rem; }
    }

    .hero-badge {
        display: inline-block;
        background-color: var(--color-mantequilla);
        color: var(--color-chocolate);
        padding: 0.5rem 1rem;
        border-radius: 9999px;
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 1rem;
    }

    .hero-title {
        font-family: var(--font-serif);
        font-size: 2rem;
        font-weight: 700;
        color: #FFF8F0;
        line-height: 1.2;
        margin-bottom: 1rem;
        text-shadow: 2px 4px 8px rgba(0, 0, 0, 0.3);
    }

    @media (min-width: 768px) {
        .hero-title { font-size: 3rem; }
    }

    .hero-subtitle {
        font-size: 1rem;
        color: rgba(255, 248, 240, 0.9);
        max-width: 650px;
        margin: 0 auto 1.5rem;
        line-height: 1.6;
        text-shadow: 1px 2px 4px rgba(0, 0, 0, 0.3);
    }

    .hero-align-left .hero-subtitle {
        margin-left: 0;
        margin-right: auto;
    }

    .hero-ctas {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 1rem;
        margin-top: 0.5rem;
    }

    .hero-align-left .hero-ctas {
        justify-content: flex-start;
    }

    .btn-hero {
        padding: 0.75rem 1.5rem;
        font-size: 0.9rem;
        font-weight: 600;
        border-radius: 0.5rem;
        transition: all 0.3s ease;
    }

    .btn-hero:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.2);
    }

    .btn-outline-hero {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem;
        border-radius: 0.5rem;
        font-size: 0.9rem;
        font-weight: 600;
        text-decoration: none;
        cursor: pointer;
        border: 2px solid rgba(255, 248, 240, 0.8);
        background-color: transparent;
        color: #FFF8F0;
        transition: all 0.3s ease;
    }

    .btn-outline-hero:hover {
        background-color: rgba(255, 248, 240, 0.15);
        border-color: #FFF8F0;
    }

    .scroll-indicator {
        position: absolute;
        bottom: 1.5rem;
        left: 50%;
        transform: translateX(-50%);
        background: rgba(255, 248, 240, 0.25);
        border: 2px solid rgba(255, 248, 240, 0.5);
        border-radius: 50%;
        width: 44px;
        height: 44px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #FFF8F0;
        cursor: pointer;
        animation: bounce 2s infinite;
        z-index: 3;
        transition: background-color 0.3s ease;
    }

    .scroll-indicator:hover {
        background: rgba(255, 248, 240, 0.35);
    }

    @keyframes bounce {
        0%, 20%, 50%, 80%, 100% { transform: translateX(-50%) translateY(0); }
        40% { transform: translateX(-50%) translateY(-10px); }
        60% { transform: translateX(-50%) translateY(-5px); }
    }
</style>

<script>
    const scrollIndicator = document.querySelector('.scroll-indicator');
    scrollIndicator?.addEventListener('click', () => {
        const hero = scrollIndicator.closest('.page-hero');
        const nextSection = hero?.nextElementSibling;
        nextSection?.scrollIntoView({ behavior: 'smooth' });
    });
</script>