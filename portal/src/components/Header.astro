---
// Header Component - Finca La Habanera Portal

interface Props {
  currentPath?: string;
}

const { currentPath = "" } = Astro.props;

const navLinks = [
  { href: "/", label: "Inicio" },
  { href: "/productos", label: "Productos" },
  { href: "/galeria", label: "Galeria" },
  { href: "/turismo", label: "Turismo Rural" },
  { href: "/contacto", label: "Contacto" },
];

const isActive = (href: string) => {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
};
---

<header class="header">
  <div class="container">
    <nav class="nav">
      <a href="/" class="logo">
        <img src="/Logo.png" alt="La Habanera" class="logo-img" />
        <div class="logo-text">
          <span class="logo-name">La Habanera</span>
          <span class="logo-tagline">Finca Caprina</span>
        </div>
      </a>

      <button class="nav-toggle" aria-label="Menu">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>

      <ul class="nav-menu">
        {
          navLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class={`nav-link ${isActive(link.href) ? "active" : ""}`}
              >
                {link.label}
                <span class="nav-underline" />
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style is:global>
  .header {
    position: sticky;
    top: 0;
    background-color: var(--color-crema);
    box-shadow: 0 2px 10px rgba(61, 35, 20, 0.1);
    z-index: 100;
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 70px;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
  }

  .logo-img {
    width: 60px;
    height: 60px;
    object-fit: contain;
    border-radius: 50%;
    flex-shrink: 0;
  }

  @media (min-width: 768px) {
    .logo-img {
      width: 55px;
      height: 55px;
    }
  }

  .logo-text {
    display: flex;
    flex-direction: column;
  }

  .logo-name {
    font-weight: 700;
    color: var(--color-chocolate);
    font-size: 1.1rem;
    line-height: 1.2;
  }

  .logo-tagline {
    font-size: 0.75rem;
    color: var(--color-tierra);
  }

  .nav-toggle {
    display: block;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-chocolate);
    padding: 0.5rem;
  }

  .nav-menu {
    display: none;
    position: absolute;
    top: 70px;
    left: 0;
    right: 0;
    background-color: var(--color-crema);
    list-style: none;
    padding: 1rem;
    margin: 0;
    box-shadow: 0 4px 10px rgba(61, 35, 20, 0.1);
  }

  .nav-menu.active {
    display: block;
  }

  .nav-link {
    position: relative;
    display: block;
    padding: 0.75rem 1rem;
    text-decoration: none;
    color: var(--color-chocolate);
    font-weight: 500;
    border-radius: 0.5rem;
    transition: all 0.2s ease;
  }

  /* Hover: fondo beige claro */
  .nav-link:hover {
    background-color: var(--color-queso);
  }

  /* Estilo del underline que crece desde el centro hacia los bordes */
  .nav-underline {
    position: absolute;
    bottom: -2px;
    left: 50%;
    width: 0;
    height: 2px;
    background-color: var(--color-mantequilla);
    transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    transform: translateX(-50%);
  }

  /* Hover: el underline crece */
  .nav-link:hover .nav-underline {
    width: 80%;
  }

  .nav-link.active {
    background-color: var(--color-mantequilla);
    color: var(--color-crema);
    box-shadow: 0 2px 8px rgba(98, 84, 45, 0.2);
  }

  .nav-link.active .nav-underline {
    width: 0;
    display: none;
  }

  @media (min-width: 768px) {
    .nav-toggle {
      display: none;
    }

    .nav-menu {
      display: flex;
      position: static;
      padding: 0;
      box-shadow: none;
      gap: 0.5rem;
    }

    .nav-link {
      display: inline-block;
      padding: 0.5rem 1rem;
    }

    /* Hover en desktop: fondo beige claro */
    .nav-link:hover {
      background-color: var(--color-queso);
      color: var(--color-chocolate);
    }

    .nav-link:hover .nav-underline {
      width: 100%;
    }

    .nav-link.active {
      background-color: transparent;
      color: var(--color-mantequilla);
      font-weight: 600;
    }

    .nav-link.active .nav-underline {
      display: none;
      width: 0;
    }
    .nav-link.active:hover {
      background-color: var(--color-queso);
      color: var(--color-mantequilla);
    }
  }
</style>

<script>
  // Mobile menu toggle
  const navToggle = document.querySelector(".nav-toggle");
  const navMenu = document.querySelector(".nav-menu");

  navToggle?.addEventListener("click", () => {
    navMenu?.classList.toggle("active");
  });

  // Close menu when clicking on a link
  document.querySelectorAll(".nav-link").forEach((link) => {
    link.addEventListener("click", () => {
      navMenu?.classList.remove("active");
    });
  });
</script>
