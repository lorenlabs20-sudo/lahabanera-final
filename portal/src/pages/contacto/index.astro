---
import MainLayout from '../../layouts/MainLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { fetchCmsData } from '../../lib/config';

// Fetch all data from CMS in one request
const data = await fetchCmsData();
const config = data.configuracion;
---

<MainLayout title="Contacto" description="Contacte a Finca La Habanera - Telefono, email, WhatsApp y formulario de contacto">
  <!-- Hero -->
  <PageHero 
    title="Contactenos"
    subtitle="Estamos aqui para ayudarle. Contactenos por telefono, email o WhatsApp, o complete el formulario y le responderemos a la brevedad."
    backgroundImage="https://images.unsplash.com/photo-1423666639041-f56000c27a9a?w=1920&q=80"
    height="medium"
    badge="Atencion Personalizada"
  />
  
  <section class="section contacto-page">
    <div class="container">
      <div class="contacto-content">
        <div class="contacto-info">
          <div class="info-card">
            <div class="info-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
            </div>
            <div class="info-text">
              <h3>Telefono</h3>
              <a href={`tel:${config.telefono || '+5353972047'}`}>{config.telefono || '+53 5 3972047'}</a>
            </div>
          </div>
          
          <div class="info-card">
            <div class="info-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect width="20" height="16" x="2" y="4" rx="2"/>
                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
              </svg>
            </div>
            <div class="info-text">
              <h3>Email</h3>
              <a href={`mailto:${config.email || 'lahaban3ra@gmail.com'}`}>{config.email || 'lahaban3ra@gmail.com'}</a>
            </div>
          </div>
          
          <div class="info-card whatsapp-card">
            <div class="info-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <div class="info-text">
              <h3>WhatsApp</h3>
              <a href={`https://wa.me/${(config.whatsapp || '+5353972047').replace(/\+/g, '')}?text=Hola%2C%20quisiera%20mas%20informacion%20sobre%20sus%20productos`} target="_blank" rel="noopener">
                Enviar mensaje
              </a>
            </div>
          </div>
          
          <div class="info-card">
            <div class="info-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <div class="info-text">
              <h3>Direccion</h3>
              <p>{config.direccion || 'Km 38-1/2, Carretera Central, San Pedro, San Jose de Las Lajas, Mayabeque, Cuba'}</p>
            </div>
          </div>
          
          <div class="social-section">
            <h3>Siganos</h3>
            <div class="social-links">
              {config.instagram && (
                <a href={config.instagram} target="_blank" rel="noopener" class="social-link">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
                    <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                    <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
                  </svg>
                  Instagram
                </a>
              )}
              {config.facebook && (
                <a href={config.facebook} target="_blank" rel="noopener" class="social-link">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
                  </svg>
                  Facebook
                </a>
              )}
              {!config.instagram && !config.facebook && (
                <p class="no-social">Proximamente</p>
              )}
            </div>
          </div>
        </div>
        
        <div class="contacto-form-container">
          <h2>Envienos un Mensaje</h2>
          <form id="contacto-form" class="contacto-form">
            <div class="form-row">
              <div class="form-group">
                <label for="nombre" class="form-label">Nombre *</label>
                <input type="text" id="nombre" name="nombre" required class="form-input" placeholder="Su nombre">
              </div>
            </div>
            
            <div class="form-row two-cols">
              <div class="form-group">
                <label for="email" class="form-label">Email *</label>
                <input type="email" id="email" name="email" required class="form-input" placeholder="correo@ejemplo.com">
              </div>
              <div class="form-group">
                <label for="telefono" class="form-label">Telefono</label>
                <input type="tel" id="telefono" name="telefono" class="form-input" placeholder="+53 5 XXX XXXX">
              </div>
            </div>
            
            <div class="form-row">
              <div class="form-group">
                <label for="asunto" class="form-label">Asunto *</label>
                <input type="text" id="asunto" name="asunto" required class="form-input" placeholder="Asunto de su mensaje">
              </div>
            </div>
            
            <div class="form-row">
              <div class="form-group">
                <label for="mensaje" class="form-label">Mensaje *</label>
                <textarea id="mensaje" name="mensaje" required class="form-textarea" placeholder="Escriba su mensaje aqui..."></textarea>
              </div>
            </div>
            
            <button type="submit" class="btn btn-accent btn-full">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m22 2-7 20-4-9-9-4Z"/>
                <path d="M22 2 11 13"/>
              </svg>
              Enviar Mensaje
            </button>
          </form>
          
          <div id="contacto-success" class="success-message" style="display: none;">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
              <polyline points="22 4 12 14.01 9 11.01"/>
            </svg>
            <h3>Mensaje Enviado</h3>
            <p>Gracias por contactarnos. Le responderemos a la brevedad.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .contacto-page {
    background-color: var(--color-crema);
  }
  
  .contacto-content {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  
  @media (min-width: 1024px) {
    .contacto-content {
      grid-template-columns: 1fr 1.5fr;
    }
  }
  
  .info-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    background-color: white;
    padding: 1.25rem;
    border-radius: 1rem;
    margin-bottom: 1rem;
    box-shadow: 0 2px 10px rgba(61, 35, 20, 0.1);
  }
  
  .whatsapp-card {
    background-color: #25D366;
    color: white;
  }
  
  .whatsapp-card h3 {
    color: white;
  }
  
  .whatsapp-card a {
    color: white;
    font-weight: 600;
  }
  
  .info-icon {
    width: 48px;
    height: 48px;
    background-color: var(--color-queso);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  
  .whatsapp-card .info-icon {
    background-color: rgba(255, 255, 255, 0.2);
    color: white;
  }
  
  .info-text h3 {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-chocolate);
    margin-bottom: 0.25rem;
  }
  
  .info-text a,
  .info-text p {
    color: var(--color-cafe);
    text-decoration: none;
    font-size: 0.95rem;
    margin: 0;
  }
  
  .info-text a:hover {
    color: var(--color-mantequilla);
  }
  
  .social-section {
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-queso);
  }
  
  .social-section h3 {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-chocolate);
    margin-bottom: 1rem;
  }
  
  .social-links {
    display: flex;
    gap: 1rem;
  }
  
  .social-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    background-color: white;
    border-radius: 0.5rem;
    text-decoration: none;
    color: var(--color-chocolate);
    font-weight: 500;
    box-shadow: 0 2px 8px rgba(61, 35, 20, 0.1);
    transition: transform 0.2s ease;
  }
  
  .social-link:hover {
    transform: translateY(-2px);
  }
  
  .no-social {
    color: var(--color-tierra);
    font-style: italic;
  }
  
  .contacto-form-container {
    background-color: white;
    padding: 2rem;
    border-radius: 1rem;
    box-shadow: 0 4px 20px rgba(61, 35, 20, 0.1);
  }
  
  .contacto-form-container h2 {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-chocolate);
    margin-bottom: 1.5rem;
  }
  
  .form-row {
    margin-bottom: 1rem;
  }
  
  .form-row.two-cols {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }
  
  @media (min-width: 640px) {
    .form-row.two-cols {
      grid-template-columns: 1fr 1fr;
    }
  }
  
  .btn-full {
    width: 100%;
    margin-top: 0.5rem;
  }
  
  .success-message {
    text-align: center;
    padding: 2rem;
  }
  
  .success-message svg {
    color: var(--color-verde);
    margin-bottom: 1rem;
  }
  
  .success-message h3 {
    font-size: 1.25rem;
    color: var(--color-chocolate);
    margin-bottom: 0.5rem;
  }
  
  .success-message p {
    color: var(--color-tierra);
  }
</style>

<script>
  const form = document.getElementById('contacto-form') as HTMLFormElement | null;
  const successDiv = document.getElementById('contacto-success');
  
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const formData = new FormData(form);
    const data = {
      nombre: formData.get('nombre'),
      email: formData.get('email'),
      telefono: formData.get('telefono'),
      asunto: formData.get('asunto'),
      mensaje: formData.get('mensaje'),
      leido: false
    };
    
    try {
      const response = await fetch('/api/mensajes?XTransformPort=3000', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(data)
      });
      
      if (response.ok) {
        form.style.display = 'none';
        if (successDiv) successDiv.style.display = 'block';
      } else {
        alert('Hubo un error al enviar el mensaje. Por favor, intente de nuevo.');
      }
    } catch (error) {
      console.error('Error:', error);
      alert('Hubo un error al enviar el mensaje. Por favor, intente de nuevo.');
    }
  });
</script>