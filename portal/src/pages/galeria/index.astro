---
import MainLayout from '../../layouts/MainLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { fetchCmsData } from '../../lib/config';

// Fetch all data from CMS in one request
const data = await fetchCmsData();
const imagenes = data.galeria || [];
---

<MainLayout title="Galeria" description="Galeria de imagenes de Finca La Habanera - Nuestra finca, cabras y productos">
  <!-- Hero -->
  <PageHero 
    title="Galeria"
    subtitle="Conozca nuestra finca, nuestras cabras y nuestro proceso productivo a traves de nuestras imagenes"
    backgroundImage="https://images.unsplash.com/photo-1516467508483-a7212febe31a?w=1920&q=80"
    height="medium"
    badge="Nuestra Finca"
  />
  
  <section class="section galeria-page">
    <div class="container">
      {imagenes.length > 0 ? (
        <div class="galeria-grid">
          {imagenes.map((imagen: any, index: number) => (
            <div class="galeria-item" data-index={index}>
              <img 
                src={imagen.url} 
                alt={imagen.alt || imagen.nombre}
                loading="lazy"
                class="galeria-img"
              />
              <div class="galeria-overlay">
                <span>{imagen.nombre}</span>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="galeria-placeholder">
          <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect width="18" height="18" x="3" y="3" rx="2" ry="2"/>
            <circle cx="9" cy="9" r="2"/>
            <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
          </svg>
          <p>Las imagenes se mostraran proximamente</p>
        </div>
      )}
    </div>
  </section>
  
  <!-- Lightbox Modal -->
  <div class="lightbox" id="lightbox">
    <button class="lightbox-close" aria-label="Cerrar">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 6 6 18"/>
        <path d="m6 6 12 12"/>
      </svg>
    </button>
    <button class="lightbox-prev" aria-label="Anterior">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="m15 18-6-6 6-6"/>
      </svg>
    </button>
    <img class="lightbox-img" src="" alt="" />
    <button class="lightbox-next" aria-label="Siguiente">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="m9 18 6-6-6-6"/>
      </svg>
    </button>
  </div>
</MainLayout>

<style>
  .galeria-page {
    background-color: var(--color-crema);
  }
  
  .galeria-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }
  
  @media (min-width: 640px) {
    .galeria-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  
  @media (min-width: 1024px) {
    .galeria-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  
  .galeria-item {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    border-radius: 0.75rem;
    cursor: pointer;
  }
  
  .galeria-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  
  .galeria-item:hover .galeria-img {
    transform: scale(1.05);
  }
  
  .galeria-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(61, 35, 20, 0.8) 0%, transparent 50%);
    opacity: 0;
    transition: opacity 0.3s ease;
    display: flex;
    align-items: flex-end;
    padding: 1rem;
  }
  
  .galeria-item:hover .galeria-overlay {
    opacity: 1;
  }
  
  .galeria-overlay span {
    color: white;
    font-size: 0.9rem;
    font-weight: 500;
  }
  
  .galeria-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem;
    background-color: var(--color-queso);
    border-radius: 1rem;
    text-align: center;
  }
  
  .galeria-placeholder svg {
    color: var(--color-mantequilla);
    margin-bottom: 1rem;
  }
  
  .galeria-placeholder p {
    color: var(--color-tierra);
  }
  
  /* Lightbox */
  .lightbox {
    position: fixed;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.95);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 2000;
    padding: 1rem;
  }
  
  .lightbox.active {
    display: flex;
  }
  
  .lightbox-img {
    max-width: 90%;
    max-height: 90vh;
    object-fit: contain;
    border-radius: 0.5rem;
  }
  
  .lightbox-close,
  .lightbox-prev,
  .lightbox-next {
    position: absolute;
    background-color: rgba(255, 255, 255, 0.1);
    border: none;
    color: white;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background-color 0.2s ease;
  }
  
  .lightbox-close:hover,
  .lightbox-prev:hover,
  .lightbox-next:hover {
    background-color: rgba(255, 255, 255, 0.2);
  }
  
  .lightbox-close {
    top: 1rem;
    right: 1rem;
  }
  
  .lightbox-prev {
    left: 1rem;
    top: 50%;
    transform: translateY(-50%);
  }
  
  .lightbox-next {
    right: 1rem;
    top: 50%;
    transform: translateY(-50%);
  }
</style>

<script define:vars={{ imagenes }}>
  const galeriaItems = document.querySelectorAll('.galeria-item');
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = lightbox?.querySelector('.lightbox-img');
  const closeBtn = lightbox?.querySelector('.lightbox-close');
  const prevBtn = lightbox?.querySelector('.lightbox-prev');
  const nextBtn = lightbox?.querySelector('.lightbox-next');
  
  let currentIndex = 0;
  const images = imagenes;
  
  function openLightbox(index) {
    currentIndex = index;
    if (lightboxImg && images[index]) {
      lightboxImg.src = images[index].url;
      lightboxImg.alt = images[index].nombre;
    }
    lightbox?.classList.add('active');
  }
  
  function closeLightbox() {
    lightbox?.classList.remove('active');
  }
  
  function showPrev() {
    currentIndex = (currentIndex - 1 + images.length) % images.length;
    if (lightboxImg && images[currentIndex]) {
      lightboxImg.src = images[currentIndex].url;
    }
  }
  
  function showNext() {
    currentIndex = (currentIndex + 1) % images.length;
    if (lightboxImg && images[currentIndex]) {
      lightboxImg.src = images[currentIndex].url;
    }
  }
  
  galeriaItems.forEach((item, index) => {
    item.addEventListener('click', () => openLightbox(index));
  });
  
  closeBtn?.addEventListener('click', closeLightbox);
  prevBtn?.addEventListener('click', showPrev);
  nextBtn?.addEventListener('click', showNext);
  
  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });
  
  document.addEventListener('keydown', (e) => {
    if (!lightbox?.classList.contains('active')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') showPrev();
    if (e.key === 'ArrowRight') showNext();
  });
</script>